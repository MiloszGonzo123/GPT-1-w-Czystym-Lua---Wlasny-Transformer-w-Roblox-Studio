local ex = false
function Config.exportConfigToOutput()
	if ex == true then return end
	ex = true
	print("local Config = {}")
	print("")

	-- Podstawowe parametry
	print("Config.heads = " .. tostring(Config.heads))
	print("Config.warstwyy = " .. tostring(Config.warstwyy))
	print("Config.repetition_penalty = " .. tostring(Config.repetition_penalty))
	print("")

	-- Vocab
	local vocabStr = 'Config.Vocab = { '
	for i, word in ipairs(Config.Vocab) do
		vocabStr = vocabStr .. '"' .. word .. '"'
		if i < #Config.Vocab then vocabStr = vocabStr .. ", " end
	end
	print(vocabStr .. " }")
	print("")

	-- WordToID
	print("Config.WordToID = {}")
	print("for id, word in ipairs(Config.Vocab) do")
	print("    Config.WordToID[word] = id")
	print("end")
	print("")

	-- EmbeddingTable
	print("Config.EmbeddingTable = {")
	for i, row in ipairs(Config.EmbeddingTable) do
		local rowStr = "    { "
		for j, val in ipairs(row) do
			rowStr = rowStr .. string.format("% .2f", val)
			if j < #row then rowStr = rowStr .. ", " end
		end
		rowStr = rowStr .. " }"
		if i < #Config.EmbeddingTable then rowStr = rowStr .. "," end
		rowStr = rowStr .. " -- " .. (Config.Vocab[i] or "?")
		print(rowStr)
	end
	print("}")
	print("")

	-- LM_Head
	print("Config.LM_Head = {")
	print("    weights = {")
	for i, row in ipairs(Config.LM_Head.weights) do
		local rowStr = "        { "
		for j, val in ipairs(row) do
			rowStr = rowStr .. string.format("% .1f", val)
			if j < #row then rowStr = rowStr .. ", " end
		end
		rowStr = rowStr .. " }"
		if i < #Config.LM_Head.weights then rowStr = rowStr .. "," end
		rowStr = rowStr .. " -- " .. (Config.Vocab[i] or "?")
		print(rowStr)
	end
	print("    },")

	local biasStr = "    biases = { "
	for i, val in ipairs(Config.LM_Head.biases) do
		biasStr = biasStr .. string.format("%.1f", val)
		if i < #Config.LM_Head.biases then biasStr = biasStr .. ", " end
	end
	print(biasStr .. " }")
	print("}")
	print("")

	-- FeedForward
	print("Config.FeedForward = {")

	-- FF[1]
	print("    {")
	print("        weights = {")
	for i, row in ipairs(Config.FeedForward[1].weights) do
		local rowStr = "            { "
		for j, val in ipairs(row) do
			rowStr = rowStr .. string.format("% .6f", val)
			if j < #row then rowStr = rowStr .. ", " end
		end
		rowStr = rowStr .. " }"
		if i < #Config.FeedForward[1].weights then rowStr = rowStr .. "," end
		print(rowStr)
	end
	print("        },")

	local ff1bStr = "        biases = { "
	for i, val in ipairs(Config.FeedForward[1].biases) do
		ff1bStr = ff1bStr .. string.format("%.6f", val)
		if i < #Config.FeedForward[1].biases then ff1bStr = ff1bStr .. ", " end
	end
	print(ff1bStr .. " }")
	print("    },")

	-- FF[2]
	print("    {")
	print("        weights = {")
	for i, row in ipairs(Config.FeedForward[2].weights) do
		local rowStr = "            { "
		for j, val in ipairs(row) do
			rowStr = rowStr .. string.format("% .6f", val)
			if j < #row then rowStr = rowStr .. ", " end
		end
		rowStr = rowStr .. " }"
		if i < #Config.FeedForward[2].weights then rowStr = rowStr .. "," end
		print(rowStr)
	end
	print("        },")

	local ff2bStr = "        biases = { "
	for i, val in ipairs(Config.FeedForward[2].biases) do
		ff2bStr = ff2bStr .. string.format("%.6f", val)
		if i < #Config.FeedForward[2].biases then ff2bStr = ff2bStr .. ", " end
	end
	print(ff2bStr .. " }")
	print("    }")

	print("}")
	print("")

	-- Warstwy
	print("Config.warstwy = {")
	local keys = {"Wq","Wk","Wv","Wo","Bq","Bk","Bv","Bo"}
	for i = 1, 12 do
		local name = "v" .. i
		local layer = Config.warstwy[name]
		if layer then
			local layerStr = "    " .. name .. " = { "
			for k, key in ipairs(keys) do
				local val = layer[key]
				if type(val) == "table" then
					-- Wq/Wk/Wv/Wo jako wektory
					local vecStr = "{ "
					for d = 1, #val do
						vecStr = vecStr .. string.format("%.6f", val[d])
						if d < #val then vecStr = vecStr .. ", " end
					end
					layerStr = layerStr .. key .. " = " .. vecStr .. " }"
				else
					-- Bq/Bk/Bv/Bo jako skalary
					layerStr = layerStr .. key .. " = " .. string.format("%.6f", val or 0)
				end
				if k < #keys then layerStr = layerStr .. ", " end
			end
			layerStr = layerStr .. " }"
			if i < 12 then layerStr = layerStr .. "," end
			print(layerStr)
		end
	end
	print("}")
	print("")

	print("return Config")
end


return Config
